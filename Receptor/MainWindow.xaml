<Window x:Class="ListenerApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Overlay" Height="300" Width="300" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent" 
        Topmost="True" ShowInTaskbar="False">
    <Grid>
        <Ellipse Width="280" Height="280" Fill="#99000000" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Ellipse.Effect>
                <BlurEffect Radius="25"/>
            </Ellipse.Effect>
        </Ellipse>

        <Canvas x:Name="MainCanvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Button Content="❌" Canvas.Right="10" Canvas.Top="10" 
                    Background="#CC000000" Foreground="White" BorderThickness="1" BorderBrush="White" 
                    FontSize="14" Padding="4,-2,4,0" Cursor="Hand" Click="CloseButton_Click" Panel.ZIndex="999"/>

            <ToggleButton x:Name="TtsButton" Content="🔊" Canvas.Right="45" Canvas.Top="10" 
                          Background="#CC000000" Foreground="White" BorderThickness="1" BorderBrush="White" 
                          FontSize="14" Padding="4,-2,4,0" Cursor="Hand" IsChecked="True" 
                          Click="TtsButton_Click" Panel.ZIndex="999"/>

            <Border Canvas.Left="95" Canvas.Top="95" Width="110" Height="110" Background="#DD0000" CornerRadius="55" Panel.ZIndex="10">
                <Border.Effect>
                    <DropShadowEffect Color="#FF3333" BlurRadius="30" ShadowDepth="0" Opacity="1"/>
                </Border.Effect>
                <TextBlock Text="BOSS" HorizontalAlignment="Center" VerticalAlignment="Center" 
                           FontSize="24" FontWeight="Black" Foreground="White"/>
            </Border>
        </Canvas>
    </Grid>
</Window>